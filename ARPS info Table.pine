//Squeeze Mom
    table.cell(tbl, 1, 17, sqzGoLong ? '⬆️' : '---', bgcolor=color.green, width=5, height=4)
    table.cell(tbl, 2, 17, '---', bgcolor=#aaaaaa, width=3, height=4)
    table.cell(tbl, 3, 17, sqzGoShort ? '⬇️' : '---', bgcolor=color.red, width=5, height=4)



var tbl2 = table.new(position.bottom_center, 1, 2)
if barstate.islast
    table.cell(tbl2, 0, 0, 'Ali Rajabpour-Sanati', bgcolor=#aaaaaa00, text_color = color.rgb(255, 255, 255, 20), width=20, height=5)
    table.cell(tbl2, 0, 1, 'ali.poursanati@gmail.com', bgcolor=#aaaaaa00, text_size = size.tiny, text_color = color.rgb(255, 255, 255, 5), width=20, height=4)
